# === GitHub SSH key setup ===
github_ssh_setup() {
  local EMAIL="$1"
  local LABEL="${2:-github}"
  local FORCE="${3:-}"

  if [ -z "$EMAIL" ]; then
    echo "Usage: github_ssh_setup your_email@example.com [label] [--force]"
    echo "Example: github_ssh_setup me@domain.com myuser --force"
    return 1
  fi

  local KEY_PATH="$HOME/.ssh/id_ed25519_${LABEL}"

  mkdir -p "$HOME/.ssh"
  chmod 700 "$HOME/.ssh"

  if [ "$FORCE" = "--force" ]; then
    local ts
    ts="$(date +%Y%m%d_%H%M%S)"
    [ -f "$KEY_PATH" ] && mv -f "$KEY_PATH" "${KEY_PATH}.bak.${ts}"
    [ -f "${KEY_PATH}.pub" ] && mv -f "${KEY_PATH}.pub" "${KEY_PATH}.pub.bak.${ts}"
  fi

  if [ -f "$KEY_PATH" ]; then
    echo "[INFO] SSH key already exists at $KEY_PATH"
  else
    echo "[INFO] Generating new ED25519 SSH key at $KEY_PATH ..."
    ssh-keygen -t ed25519 -a 64 -C "$EMAIL" -f "$KEY_PATH"
  fi

  # Prefer a local agent for this shell
  eval "$(ssh-agent -s)" >/dev/null 2>&1
  ssh-add "$KEY_PATH" >/dev/null

  echo ""
  echo "===== COPY THIS PUBLIC KEY TO GITHUB ====="
  cat "${KEY_PATH}.pub"
  echo "=========================================="
  echo ""
  echo "Test with (forces this key):"
  echo "ssh -i \"$KEY_PATH\" -o IdentitiesOnly=yes -T git@github.com"
}
